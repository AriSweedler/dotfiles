#!/usr/bin/env zsh
#
# Print the PR number bound to a Claude Code session.
#
# Source of truth: the most recent {"type":"pr-link","prNumber":N,...} record
# in ~/.claude/projects/*/<uuid>.jsonl. Claude writes this when the session is
# started via `claude --from-pr <N>` or a /resume PR URL paste. No binding →
# non-zero exit, no stdout.

set -euo pipefail

readonly PROJECTS_DIR="${HOME}/.claude/projects"

export OTTO_LOG_NOTIF_GROUP="claude-pr-from-session"
export OTTO_LOG_NOTIF_TITLE="claude: pr-from-session"
export OTTO_DEBUG="${OTTO_DEBUG:-1}"
source "${HOME}/.config/zsh/plugins/log.zsh"
log::redirect_all_output_to_logfile

# --- Help ---

help() {
  cat <<EOF
${c_green}claude-pr-from-session${c_rst} — print the PR number for a Claude Code session

${c_cyan}Usage:${c_rst}
  claude-pr-from-session <session-uuid>

${c_cyan}Options:${c_rst}
  --verbose   OTTO_DEBUG=1 (debug logs on; default)
  --quiet     OTTO_DEBUG=0 (debug logs off)
  -h, --help  Show this help
EOF
}

# --- Main ---

main() {
  # === PREREQUISITES ===
  local -a missing
  for cmd in jq find tail; do
    command -v "${cmd}" >/dev/null 2>&1 || missing+=("${cmd}")
  done
  if (( ${#missing} > 0 )); then
    log::err "Missing required commands | missing='${(j:, :)missing}'"
    return 1
  fi

  # === PARSE ===
  local raw_args="${*}"
  local uuid=""
  while (( $# > 0 )); do case "${1}" in
    -h|--help)  help; return 0 ;;
    --verbose)  export OTTO_DEBUG=1; shift ;;
    --quiet)    export OTTO_DEBUG=0; shift ;;
    -*)         log::err "Unknown flag | flag='${1}'"; help; return 1 ;;
    *)          [[ -z "${uuid}" ]] || { log::err "Multiple UUIDs given | first='${uuid}' second='${1}'"; return 1; }
                uuid="${1}"; shift ;;
  esac; done
  log::debug "Run started | pid=$$ args='${raw_args}'"

  # === VALIDATE ===
  uuid="${uuid:l}"
  if [[ ! "${uuid}" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
    log::err "Not a valid UUID | uuid='${uuid}'"
    return 1
  fi

  # === LOGIC ===
  local jsonl
  jsonl="$(find "${PROJECTS_DIR}" -maxdepth 2 -name "${uuid}.jsonl" -type f 2>/dev/null | head -1)"
  if [[ -z "${jsonl}" ]]; then
    log::err "No session file found | uuid='${uuid}' projects_dir='${PROJECTS_DIR}'"
    return 1
  fi
  log::debug "Session file | jsonl='${jsonl}'"

  # Reverse-walk + grep -m1: stops at the most recent pr-link record
  # regardless of file size. `|| true` swallows the SIGPIPE that grep -m1
  # forces on tail -r under `set -o pipefail`.
  local pr
  pr="$(tail -r "${jsonl}" 2>/dev/null \
    | grep -m1 '"type":"pr-link"' \
    | jq -r '.prNumber // empty' 2>/dev/null || true)"
  if [[ -z "${pr}" ]]; then
    # Forked sessions deliberately not handled: claude UI may show a PR for
    # them (probably from in-memory state inherited at fork time), but we want
    # the bail to surface that this session's own JSONL has no binding.
    local forked_from
    forked_from="$(head -1 "${jsonl}" 2>/dev/null \
      | jq -r '.forkedFrom.sessionId // empty' 2>/dev/null)"
    log::err "no active PR | uuid='${uuid}' jsonl='${jsonl}' forked_from='${forked_from:-<none>}'"
    return 1
  fi
  log::debug "PR resolved | pr='${pr}' uuid='${uuid}'"

  echo "${pr}"
}

main "${@}"
