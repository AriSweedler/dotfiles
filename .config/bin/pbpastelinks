#!/usr/bin/env zsh
# Expand rich-text links on the clipboard into plain "text url" lines.
#
# Architecture:
#   1. A Swift binary (pbpastelinks-extract) reads every NSPasteboard flavor
#      and returns HTML to stdout. It handles public.html, Chromium's
#      web-custom-data (including Slack's Quill JSON), public.rtf via
#      NSAttributedString, and Apple Web Archive. Source lives at
#      ${SWIFT_SRC}; it's lazy-compiled to ${SWIFT_BIN} on first run.
#   2. A perl regex walks the HTML and emits "text url" lines.
#   3. zsh wires the two together and rewrites the clipboard.
#
# On no-match the clipboard is left untouched — overwriting empty would
# destroy work.
set -euo pipefail

readonly LOG_LIB="${HOME}/.config/zsh/plugins/log.zsh"
[[ -r "${LOG_LIB}" ]] || { print -r -- "[pbpastelinks] missing log lib | path='${LOG_LIB}'" >&2; exit 1; }
source "${LOG_LIB}"

readonly SWIFT_SRC="${HOME}/.config/bin/pbpastelinks-extract.swift"
readonly SWIFT_BIN="${HOME}/.cache/pbpastelinks/extract"

#######################################
# Verify required binaries exist.
# Globals: None
# Arguments: None
# Returns: 1 if any are missing
#######################################
check_prerequisites() {
  local missing=()
  local cmd
  for cmd in pbcopy perl swiftc; do
    command -v "${cmd}" >/dev/null 2>&1 || missing+=("${cmd}")
  done
  if (( ${#missing} > 0 )); then
    log::err "missing required commands | missing='${(j:, :)missing}'"
    return 1
  fi
}

#######################################
# Compile the Swift extractor to ${SWIFT_BIN} if missing or older than source.
# Globals: SWIFT_SRC, SWIFT_BIN
# Returns: 1 on compile failure
#######################################
ensure_extractor() {
  if [[ ! -r "${SWIFT_SRC}" ]]; then
    log::err "missing swift source | path='${SWIFT_SRC}'"
    return 1
  fi
  if [[ -x "${SWIFT_BIN}" && "${SWIFT_BIN}" -nt "${SWIFT_SRC}" ]]; then
    return 0
  fi
  log::info "compiling extractor | src='${SWIFT_SRC}' bin='${SWIFT_BIN}'"
  mkdir -p "${SWIFT_BIN:h}"
  if swiftc -O -o "${SWIFT_BIN}" "${SWIFT_SRC}"; then
    log::info "compiled | bin='${SWIFT_BIN}'"
    return 0
  fi
  log::err "swift compile failed | src='${SWIFT_SRC}'"
  return 1
}

help() {
  local cg=$'\e[32m' cc=$'\e[36m' cr=$'\e[0m'
  cat <<EOF
${cg}pbpastelinks${cr} — flatten clipboard rich-text links into "text url" lines

Reads every NSPasteboard flavor (HTML, Chromium web-custom-data, RTF,
Web Archive) via an embedded Swift extractor, then emits one "text url"
line per <a href=...> anchor. The clipboard is replaced with the flat
output so you can paste into terminals / plain-text destinations.

Works with copies from:
  - Google Docs, GitHub, generic web pages (public.html)
  - Slack desktop / web (Chromium web-custom-data → text/html or slack/text)
  - Mail, TextEdit, Notes, Word (public.rtf → NSAttributedString)
  - Safari (Apple Web Archive)

${cc}Usage:${cr}
  pbpastelinks [--quiet] [--rebuild]
  pbpastelinks -h | --help

${cc}Options:${cr}
  --quiet      Suppress stderr logging (still prints output on stdout)
  --rebuild    Force recompile the swift extractor binary
  -h, --help   Show this help

${cc}Diagnostics:${cr}
  Every step logs to stderr at INFO. The swift extractor lists every
  pasteboard flavor present and which strategy it picked. The zsh wrapper
  logs each anchor it extracts and the final clipboard write.
EOF
}

main() {
  check_prerequisites || return 1

  # === PARSE ===
  local quiet=false rebuild=false
  while (( $# > 0 )); do case "${1}" in
    -h|--help) help; return 0 ;;
    --quiet)   quiet=true; shift ;;
    --rebuild) rebuild=true; shift ;;
    -*)        log::err "unknown flag | flag='${1}'"; help; return 1 ;;
    *)         log::err "unexpected argument | argument='${1}'"; help; return 1 ;;
  esac; done

  # === MASSAGE ===
  if [[ "${quiet}" == "true" ]]; then
    export OTTO_NO_PREAMBLE=1
    log::info() { :; }
    log::warn() { :; }
  fi

  if [[ "${rebuild}" == "true" && -e "${SWIFT_BIN}" ]]; then
    log::info "force rebuild | removing='${SWIFT_BIN}'"
    rm -f "${SWIFT_BIN}"
  fi

  ensure_extractor || return 1

  # === LOGIC ===
  # Swift extractor emits its own diagnostic block to stderr on failure
  # (FAIL/hint/flavor list/preview). On success it logs one "hit" line.
  # The wrapper stays quiet on failure and only logs the post-extract steps.
  local html rc=0
  html="$("${SWIFT_BIN}")" || rc="${?}"

  if (( rc != 0 )); then
    # Swift already explained why; don't double-log. Pass exit code through
    # so callers can branch on it.
    return "${rc}"
  fi

  if [[ -z "${html}" ]]; then
    log::warn "extractor returned rc=0 but no html — bug in extractor"
    return 0
  fi

  local -a links
  local line
  while IFS= read -r line; do
    [[ -z "${line}" ]] && continue
    links+=("${line}")
    log::info "anchor matched | n='${#links}' entry='${line[1,200]}'"
  done < <(printf '%s' "${html}" | extract_anchors)

  if (( ${#links} == 0 )); then
    log::warn "extractor hit but perl found no <a> anchors | clipboard left untouched"
    return 0
  fi

  local output="${(F)links}"
  printf '%s' "${output}" | pbcopy
  log::info "wrote clipboard | bytes='${#output}' count='${#links}'"

  printf '%s\n' "${output}"
}

#######################################
# Walk HTML on stdin, emit one "text url" line per <a href=...>.
# Decodes common HTML entities in both anchor text and href.
#######################################
extract_anchors() {
  perl -0777 -ne '
    sub unescape {
      my $s = shift;
      $s =~ s/&nbsp;/ /g;
      $s =~ s/&amp;/&/g;
      $s =~ s/&lt;/</g;
      $s =~ s/&gt;/>/g;
      $s =~ s/&quot;/"/g;
      $s =~ s/&#39;/'\''/g;
      $s =~ s/&#(\d+);/chr($1)/ge;
      return $s;
    }
    while (m{<a\b([^>]*)>(.*?)</a>}gis) {
      my ($attrs, $text) = ($1, $2);
      my $href;
      if    ($attrs =~ /\bhref\s*=\s*"([^"]*)"/i) { $href = $1 }
      elsif ($attrs =~ /\bhref\s*=\s*'\''([^'\'']*)'\''/i) { $href = $1 }
      else  { next }

      $text =~ s/<[^>]+>//g;
      $text = unescape($text);
      $text =~ s/\s+/ /g;
      $text =~ s/^\s+|\s+$//g;

      $href = unescape($href);

      next if $text eq "" || $href eq "";
      print "$text $href\n";
    }
  '
}

main "${@}"
