#!/usr/bin/env zsh
#
# Resolve the Claude Code session UUID of the currently-focused terminal pane.
#
# Walks:
#   frontmost app + tty (precompiled Swift binary)
#   → tmux pane tty (if a tmux client is attached on that terminal tty)
#   → `claude` process on that tty
#   → process cwd (lsof)
#   → ~/.claude/projects/<encoded-cwd>/ → session JSONL → UUID
#
# stdout: bare session UUID on success.
# stderr: log lines (also tee'd to LOG_FILE).
# exit  : 0 on success; non-zero if any step fails.

set -euo pipefail

readonly PROJECTS_DIR="${HOME}/.claude/projects"

# Precompiled helper that returns "<app>\t<tty>" for the focused terminal.
# Compiled on demand into XDG_CACHE_HOME — same pattern as pbpastelinks.
readonly FOCUS_TTY_SRC="${HOME}/.config/bin/claude-focus-tty.swift"
readonly FOCUS_TTY_BIN="${HOME}/.cache/claude-focus-tty/claude-focus-tty"

# Per-run logfile. Truncated immediately so each invocation produces a
# self-contained trace. All log:: output goes here via the tee redirect below.
readonly LOG_FILE="/tmp/claude-session-from-focus.log"
: > "${LOG_FILE}"
exec 2> >(tee -a "${LOG_FILE}" >&2)

# Ari's standard log helpers (log::info/warn/err/debug, run_cmd, preamble).
export OTTO_DEBUG=1
source "${HOME}/.config/zsh/plugins/log.zsh"

# --- Prerequisites ---

check_prerequisites() {
  local -a missing
  for cmd in lsof ps awk swiftc jq; do
    command -v "${cmd}" >/dev/null 2>&1 || missing+=("${cmd}")
  done
  if (( ${#missing} > 0 )); then
    log::err "Missing required commands | missing='${(j:, :)missing}'"
    return 1
  fi
}

#######################################
# Compile claude-focus-tty.swift to FOCUS_TTY_BIN if missing or stale. Surfaces
# a persistent notification on the (rare, one-time) compile path so the user
# knows where the extra latency went.
# Globals: FOCUS_TTY_SRC, FOCUS_TTY_BIN
# Returns: 1 on compile failure
#######################################
notify_persistent() {
  local message="${1}"
  local notifier="/opt/homebrew/bin/terminal-notifier"
  [[ -x "${notifier}" ]] || return 0
  "${notifier}" -title "claude-focus-tty" -message "${message}" \
    -group "claude-focus-tty-compile" >/dev/null 2>&1 || true
}

ensure_focus_tty() {
  if [[ ! -r "${FOCUS_TTY_SRC}" ]]; then
    log::err "missing swift source | path='${FOCUS_TTY_SRC}'"
    return 1
  fi
  if [[ -x "${FOCUS_TTY_BIN}" && "${FOCUS_TTY_BIN}" -nt "${FOCUS_TTY_SRC}" ]]; then
    return 0
  fi
  log::info "compiling focus-tty | src='${FOCUS_TTY_SRC}' bin='${FOCUS_TTY_BIN}'"
  notify_persistent "compiling claude-focus-tty (first run only) | src='${FOCUS_TTY_SRC/#$HOME/~}'"
  mkdir -p "${FOCUS_TTY_BIN:h}"
  if ! swiftc -O -o "${FOCUS_TTY_BIN}" "${FOCUS_TTY_SRC}" 2>&1 >&2; then
    log::err "swiftc failed | src='${FOCUS_TTY_SRC}'"
    notify_persistent "swiftc FAILED | src='${FOCUS_TTY_SRC/#$HOME/~}'"
    return 1
  fi
  notify_persistent "compiled claude-focus-tty | bin='${FOCUS_TTY_BIN/#$HOME/~}'"
}

# --- Help ---

help() {
  cat <<EOF
${c_green}claude-session-from-focus${c_rst} — print the session UUID of the focused Claude

${c_cyan}Usage:${c_rst}
  claude-session-from-focus

${c_cyan}Options:${c_rst}
  --verbose   Enable debug logging
  -h, --help  Show this help

${c_cyan}Output:${c_rst}
  stdout: bare session UUID on success.
  stderr: log lines (also tee'd to ${LOG_FILE}).
  exit 0 if found; non-zero if the frontmost app isn't a supported terminal,
  no claude process is on the focused pane, or the session file is missing.
EOF
}

# --- Steps ---

#######################################
# Get the frontmost terminal app + tty in one shot via the precompiled Swift
# binary. Replaces two osascript invocations.
# Globals: FOCUS_TTY_BIN
# Stdout: two lines — app name, then tty path
# Returns: non-zero if frontmost isn't a supported terminal
#######################################
focus_app_tty() {
  local output
  output="$("${FOCUS_TTY_BIN}")" || return 1
  local app="${output%%$'\t'*}"
  local tty="${output##*$'\t'}"
  printf '%s\n%s\n' "${app}" "${tty}"
}

#######################################
# If a tmux client is attached on the given terminal tty, return that client's
# currently-visible pane tty. Otherwise echo the input.
# Arguments:
#   $1 - terminal tty (e.g. /dev/ttys000)
# Stdout: pane tty
#######################################
resolve_pane_tty() {
  local term_tty="${1}"
  local pane_tty
  if ! command -v tmux >/dev/null 2>&1; then
    log::debug "tmux not installed; using terminal tty | tty='${term_tty}'"
    echo "${term_tty}"
    return
  fi
  # `-c <client-tty>` is the correct flag for "ask tmux about a specific
  # client's currently-visible pane". The previous code used `-t`, which
  # targets a pane/window — when the target didn't match a pane, tmux silently
  # fell back to the session's most-recently-active pane, so this function
  # always returned the same pane regardless of which one the user was viewing.
  pane_tty="$(tmux display-message -c "${term_tty}" -p '#{pane_tty}' 2>/dev/null || true)"
  if [[ -z "${pane_tty}" ]]; then
    log::debug "No tmux client on terminal tty; using it directly | tty='${term_tty}'"
    echo "${term_tty}"
    return
  fi
  log::debug "Tmux pane resolved | term_tty='${term_tty}' pane_tty='${pane_tty}'"
  echo "${pane_tty}"
}

#######################################
# Find the claude process on a given tty.
# Arguments:
#   $1 - tty short name (e.g. ttys014)
# Stdout: pid
# Returns: 1 if not found
#######################################
find_claude_pid() {
  local tty_short="${1}"
  local -a pids
  # macOS pgrep -t is broken for native ttys names; parse `ps -t` instead.
  pids=("${(@f)$(ps -t "${tty_short}" -o pid=,command= 2>/dev/null \
    | awk '{ cmd=$2; sub(".*/", "", cmd); if (cmd == "claude") print $1 }')}")
  pids=("${pids[@]:#}")
  if (( ${#pids} == 0 )); then
    log::err "No claude process on tty | tty='${tty_short}'"
    return 1
  fi
  if (( ${#pids} > 1 )); then
    log::warn "Multiple claude processes on tty; using first | tty='${tty_short}' pids='${(j:, :)pids}'"
  fi
  echo "${pids[1]}"
}

#######################################
# Get the cwd of a process via lsof.
# Arguments:
#   $1 - pid
# Stdout: absolute cwd path
# Returns: 1 if cwd cannot be read
#######################################
process_cwd() {
  local pid="${1}"
  local cwd
  cwd="$(lsof -a -p "${pid}" -d cwd -Fn 2>/dev/null | awk '/^n/{sub(/^n/,""); print; exit}')"
  if [[ -z "${cwd}" ]]; then
    log::err "Could not read cwd | pid='${pid}'"
    return 1
  fi
  echo "${cwd}"
}

#######################################
# Map an absolute cwd to its ~/.claude/projects/ encoding (slashes → dashes).
# Arguments:
#   $1 - cwd
# Stdout: project dir path
#######################################
project_dir_for_cwd() {
  local cwd="${1}"
  echo "${PROJECTS_DIR}/${cwd//\//-}"
}

# Canonical PID → sessionId map written by claude itself.
readonly CLAUDE_SESSIONS_DIR="${HOME}/.claude/sessions"

#######################################
# Resolve the session UUID for a specific claude PID.
# Claude maintains ${CLAUDE_SESSIONS_DIR}/<pid>.json with {pid, sessionId, ...}
# while the process is running — that's authoritative.
# Arguments:
#   $1 - claude pid
# Stdout: session UUID
# Returns: 1 if the session file is missing or malformed
#######################################
session_uuid_for_pid() {
  local pid="${1}"
  local session_file="${CLAUDE_SESSIONS_DIR}/${pid}.json"
  if [[ ! -r "${session_file}" ]]; then
    log::err "Claude session file missing | pid='${pid}' path='${session_file}'"
    return 1
  fi
  local uuid
  uuid="$(jq -r '.sessionId // empty' "${session_file}" 2>/dev/null)"
  if [[ -z "${uuid}" ]]; then
    log::err "No sessionId field in claude session file | path='${session_file}'"
    return 1
  fi
  log::debug "Session from claude PID file | pid='${pid}' uuid='${uuid}' file='${session_file}'"
  echo "${uuid}"
}

# --- Main ---

main() {
  log::debug "=== run started | pid=$$ args='${*}' ==="

  check_prerequisites || exit 1
  ensure_focus_tty || exit 1

  # === PARSE ===
  while (( $# > 0 )); do case "${1}" in
    -h|--help)  help; return 0 ;;
    --verbose)  shift ;;
    -*)         log::err "Unknown flag | flag='${1}'"; help; return 1 ;;
    *)          log::err "Unexpected argument | argument='${1}'"; help; return 1 ;;
  esac; done

  # === LOGIC ===
  local app term_tty pane_tty pane_short pid cwd proj_dir uuid
  local -a pair
  pair=("${(@f)$(focus_app_tty)}") || return 1
  app="${pair[1]}"
  term_tty="${pair[2]}"
  log::debug "Focus app+tty (from swift binary) | app='${app}' tty='${term_tty}'"

  pane_tty="$(resolve_pane_tty "${term_tty}")"
  pane_short="${pane_tty#/dev/}"
  log::info "Focused pane | app='${app}' term_tty='${term_tty}' pane_tty='${pane_tty}'"

  pid="$(find_claude_pid "${pane_short}")" || return 1
  log::debug "Claude pid | pid='${pid}' tty='${pane_short}'"

  uuid="$(session_uuid_for_pid "${pid}")" || return 1
  cwd="$(process_cwd "${pid}")" || true
  log::info "Resolved session | uuid='${uuid}' cwd='${cwd:-?}'"
  echo "${uuid}"
}

main "${@}"
