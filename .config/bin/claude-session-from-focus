#!/usr/bin/env zsh
#
# Print the session UUID of the focused Claude Code pane.
#
# * Bail if Terminal.app is not the frontmost macOS application
# * Pick the most-recently-active tmux client's currently-visible pane
# * Find the `claude` process on that pane's tty
# * Read sessionId from ~/.claude/sessions/<pid>.json
# * stdout: bare UUID; non-zero exit on any step failure.

set -euo pipefail

# Bundle ID of the terminal we expect to be frontmost. Override via env, e.g.
# TERMINAL=com.googlecode.iterm2 to switch to iTerm.
readonly TERMINAL="${TERMINAL:-com.apple.Terminal}"

export OTTO_LOG_NOTIF_GROUP="claude-session-from-focus"
export OTTO_LOG_NOTIF_TITLE="claude: session-from-focus"
export OTTO_DEBUG="${OTTO_DEBUG:-1}"
source "${HOME}/.config/zsh/plugins/log.zsh"
log::redirect_all_output_to_logfile

# --- Help ---

help() {
  cat <<EOF
${c_green}claude-session-from-focus${c_rst} — print the session UUID of the focused Claude

${c_cyan}Env:${c_rst}
  TERMINAL    Expected frontmost app bundle ID (default: com.apple.Terminal)

${c_cyan}Options:${c_rst}
  --verbose   OTTO_DEBUG=1 (debug logs on; default)
  --quiet     OTTO_DEBUG=0 (debug logs off)
  -h, --help  Show this help
EOF
}

# --- Main ---

main() {
  # === PREREQUISITES ===
  local -a missing
  for cmd in lsappinfo tmux ps awk jq; do
    command -v "${cmd}" >/dev/null 2>&1 || missing+=("${cmd}")
  done
  if (( ${#missing} > 0 )); then
    log::err "Missing required commands | missing='${(j:, :)missing}'"
    return 1
  fi

  # === PARSE ===
  local raw_args="${*}"
  while (( $# > 0 )); do case "${1}" in
    -h|--help)  help; return 0 ;;
    --verbose)  export OTTO_DEBUG=1; shift ;;
    --quiet)    export OTTO_DEBUG=0; shift ;;
    -*)         log::err "Unknown flag | flag='${1}'"; help; return 1 ;;
    *)          log::err "Unexpected argument | argument='${1}'"; help; return 1 ;;
  esac; done
  log::debug "Run started | pid=$$ args='${raw_args}'"

  # === LOGIC ===
  local front_bundle
  front_bundle="$(lsappinfo info -only bundleID "$(lsappinfo front)" 2>/dev/null \
    | awk -F'"' '/CFBundleIdentifier/{print $4}')"
  if [[ "${front_bundle}" != "${TERMINAL}" ]]; then
    log::err "Frontmost app is not the expected terminal | front_bundle='${front_bundle}' TERMINAL='${TERMINAL}'"
    return 1
  fi
  log::debug "Frontmost confirmed | front_bundle='${front_bundle}'"

  # tmux's most-recently-active client's currently-visible pane. With a single
  # tmux client (the common case) this is unambiguous.
  local pane_tty
  pane_tty="$(tmux list-clients -F '#{client_activity} #{pane_tty}' 2>/dev/null \
    | sort -rn | head -1 | awk '{print $2}')"
  if [[ -z "${pane_tty}" ]]; then
    log::err "No attached tmux client"
    return 1
  fi
  local pane_short="${pane_tty#/dev/}"
  log::debug "Tmux pane | pane_tty='${pane_tty}'"

  # macOS pgrep -t is broken for native ttys names; parse `ps -t` instead.
  local pid
  pid="$(ps -t "${pane_short}" -o pid=,command= 2>/dev/null \
    | awk '{ cmd=$2; sub(".*/", "", cmd); if (cmd == "claude") print $1 }' \
    | head -1)"
  if [[ -z "${pid}" ]]; then
    log::err "No claude process on tty | pane_short='${pane_short}'"
    return 1
  fi
  log::debug "Claude pid | pid='${pid}'"

  # Canonical PID → sessionId map written by claude itself.
  local session_file="${HOME}/.claude/sessions/${pid}.json"
  if [[ ! -r "${session_file}" ]]; then
    log::err "Claude session file missing | session_file='${session_file}'"
    return 1
  fi
  local uuid
  uuid="$(jq -r '.sessionId // empty' "${session_file}" 2>/dev/null)"
  if [[ -z "${uuid}" ]]; then
    log::err "No sessionId in claude session file | session_file='${session_file}'"
    return 1
  fi
  log::debug "Session resolved | uuid='${uuid}'"

  echo "${uuid}"
}

main "${@}"
