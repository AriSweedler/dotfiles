#!/usr/bin/env zsh
#
# Karabiner Hyper+Q handler.
#
# * Look at the active claude session. If none, bail
# * Find the 'pr-link' metadata. If none, bail
# * Open the pr

set -euo pipefail

export OTTO_LOG_NOTIF_GROUP="karabiner-open-pr-from-focussed-claude"
export OTTO_LOG_NOTIF_TITLE="karabiner->claude->go/pr"
export OTTO_DEBUG="${OTTO_DEBUG:-1}"
source "${HOME}/.config/zsh/plugins/log.zsh"
log::redirect_all_output_to_logfile

# --- Help ---

help() {
  cat <<EOF
${c_green}karabiner-open-pr-from-focussed-claude${c_rst} — Karabiner Hyper+Q handler

${c_cyan}Behavior:${c_rst}
  Focused claude session with a pr-link → open go/pr/<N>.
  Otherwise → bail with a transient notification (no fallback;
  use Hyper+P for the clipboard path).

${c_cyan}Options:${c_rst}
  --verbose   OTTO_DEBUG=1 (debug logs on; default)
  --quiet     OTTO_DEBUG=0 (debug logs off)
  -h, --help  Show this help
EOF
}

# --- Main ---

main() {
  # === PREREQUISITES ===
  local -a missing
  for cmd in claude-session-from-focus claude-pr-from-session; do
    command -v "${cmd}" >/dev/null 2>&1 || missing+=("${cmd}")
  done
  if (( ${#missing} > 0 )); then
    log::err "Missing required commands | missing='${(j:, :)missing}'"
    return 1
  fi

  # === PARSE ===
  local raw_args="${*}"
  while (( $# > 0 )); do case "${1}" in
    -h|--help)  help; return 0 ;;
    --verbose)  export OTTO_DEBUG=1; shift ;;
    --quiet)    export OTTO_DEBUG=0; shift ;;
    -*)         log::err "Unknown flag | flag='${1}'"; help; return 1 ;;
    *)          log::err "Unexpected argument | argument='${1}'"; help; return 1 ;;
  esac; done
  log::debug "Run started | pid=$$ args='${raw_args}'"

  # === LOGIC ===
  local claude_session_uuid
  if ! claude_session_uuid="$(claude-session-from-focus)"; then
    notif_lvl=err log::notify "no claude session in focused pane"
    return 1
  fi
  log::debug "Claude session resolved | claude_session_uuid='${claude_session_uuid}'"

  local pr
  if ! pr="$(claude-pr-from-session "${claude_session_uuid}")" || [[ -z "${pr}" ]]; then
    notif_lvl=err log::notify "no active PR | claude_session='${claude_session_uuid:0:8}'"
    return 1
  fi
  log::debug "Claude pr resolved | pr='${pr}'"

  log::notify "opening PR | pr='${pr}' claude_session='${claude_session_uuid:0:8}'"
  open "http://go/pr/${pr}"
}

main "${@}"
