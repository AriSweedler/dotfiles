#!/bin/bash
#
# Karabiner Hyper+N handler. Asks the Claude click-simulator to catch the
# latest notification:
#   - exit 0 (caught one) → fire Raycast confetti
#   - exit 1 (none active) → show a "no notifications to catch" alert
#
# Lives in the karabiner repo so the conditional UX stays close to the
# binding. The simulator itself is the cross-cutting Claude code in
# ~/.config/claude/bin/.

set -u

readonly NOTIFIER="/opt/homebrew/bin/terminal-notifier"
readonly CLICK_SIM="${HOME}/.config/claude/bin/notification-click-simulator.sh"
readonly CONFETTI_URL="raycast://extensions/raycast/raycast/confetti"
readonly ALERT_GROUP="claude-no-catch"
# Set to your terminal of choice (iTerm, kitty, Ghostty, ...).
readonly TERMINAL_APP="Terminal"

notify_no_catch() {
  "${NOTIFIER}" \
    -title "Claude" \
    -message "no notifications to catch" \
    -group "${ALERT_GROUP}"
  ( sleep 1 && "${NOTIFIER}" -remove "${ALERT_GROUP}" >/dev/null 2>&1 ) &
  wait
}

if ! "${CLICK_SIM}"; then
  notify_no_catch
  exit
fi
open "${CONFETTI_URL}"
open -a "${TERMINAL_APP}"
