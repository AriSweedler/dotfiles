#!/usr/bin/env zsh
#
# Karabiner Hyper+N handler: jump to a waiting notification.
#
# Claude-first for speed. A Claude notif is read from terminal-notifier (the same
# fast, FDA-free, osascript-free path Hyper+C uses, ~60ms) and wins over other
# apps — Hyper+C exists for Claude, so N favors it too. Only with no Claude notif
# do we fall to notif-center, which AX-presses the newest tray notification and,
# on a miss, opens Notification Center to recover a faded/ungrouped one:
#   1. terminal-notifier read (Claude)   — fast, == Hyper+C
#   2. notif-center click (any app)      — AX press; ~550ms grouped, ~1s if it
#                                          must open NC for a lone faded notif
set -euo pipefail

export OTTO_LOG_NOTIF_GROUP="notif-click"
export OTTO_LOG_NOTIF_TITLE="Hyper+N → notif"
# Debug ON so the full click flow lands in the rotated handler log
# (/tmp/karabiner.notif-click/log.txt — see macros.ts).
export OTTO_DEBUG="${OTTO_DEBUG:-1}"
source "${HOME}/.config/zsh/plugins/log.zsh"

readonly CLAUDE_CLICK_SIM="${HOME}/.config/claude/bin/notification-click-simulator.sh"

# 1) terminal-notifier read (the Claude sim, same fast path as Hyper+C): a waiting
#    Claude notif is caught with no osascript, and wins over a non-Claude banner.
if "${CLAUDE_CLICK_SIM}"; then
  exit 0
fi

# 2) No Claude notif → click the newest tray notification of any app. One AX press;
#    on a miss notif-center opens Notification Center to recover a faded/ungrouped
#    one (its own SLOW PATH warn fires then). --quiet defers the miss banner to (3).
log::info "no claude notif — clicking newest tray notification (any app)"
if notif-center click --quiet; then
  exit 0
fi

# 3) Everything missed → real miss; say so.
OTTO_LOG_NOTIFY_SECS=3 log::notify "No notification to click"
exit 1
