#!/usr/bin/env zsh
# Karabiner Hyper+Q handler. Resolve the PR for the focused Claude session and
# open go/pr/<N>. Bail with a transient notification if no claude session is
# focused or the session has no pr-link metadata. Hyper+P handles the
# clipboard path; this script never falls back to it.

set -euo pipefail

readonly NOTIFIER="/opt/homebrew/bin/terminal-notifier"
readonly ALERT_GROUP="karabiner-go-pr-smart"
readonly SESSION_FROM_FOCUS="${HOME}/.config/bin/claude-session-from-focus"
readonly SESSION_PR="${HOME}/.config/bin/claude-session-pr"

# How long transient notifications stick around before the cleanup process
# removes them. Override via env (e.g. KARABINER_GO_PR_NOTIFY_SECS=3).
readonly NOTIFY_SECS="${KARABINER_GO_PR_NOTIFY_SECS:-5}"

# Per-run logfile. Truncated immediately so each invocation produces a
# self-contained trace. Karabiner separately captures all stdout/stderr to
# /tmp/karabiner.karabiner-go-pr-smart.txt.
readonly LOG_FILE="/tmp/karabiner-go-pr-smart.log"
: > "${LOG_FILE}"
exec 2> >(tee -a "${LOG_FILE}" >&2)

# Ari's standard log helpers (log::info/warn/err/debug, run_cmd, preamble).
export OTTO_DEBUG=1
source "${HOME}/.config/zsh/plugins/log.zsh"

# --- Prerequisites ---

check_prerequisites() {
  local -a missing
  for cmd in "${NOTIFIER}" "${SESSION_FROM_FOCUS}" "${SESSION_PR}" open nohup; do
    if [[ "${cmd}" == /* ]]; then
      [[ -x "${cmd}" ]] || missing+=("${cmd}")
    else
      command -v "${cmd}" >/dev/null 2>&1 || missing+=("${cmd}")
    fi
  done
  if (( ${#missing} > 0 )); then
    log::err "Missing required commands | missing='${(j:, :)missing}'"
    return 1
  fi
}

# --- Help ---

help() {
  cat <<EOF
${c_green}karabiner-go-pr-smart${c_rst} — Karabiner Hyper+Q handler

${c_cyan}Behavior:${c_rst}
  Focused claude session with a pr-link → open go/pr/<N>.
  Otherwise → bail with a transient notification (no fallback;
  use Hyper+P for the clipboard path).

${c_cyan}Env:${c_rst}
  KARABINER_GO_PR_NOTIFY_SECS    How long notifications stay (default: 5)

${c_cyan}Options:${c_rst}
  --verbose   Enable debug logging
  -h, --help  Show this help
EOF
}

# --- Notifications ---

#######################################
# Show a notification and schedule its removal after NOTIFY_SECS. The cleanup
# is spawned via `nohup` + I/O detachment so it survives this script's exit —
# we don't have to block on `wait`.
# Globals: NOTIFIER, ALERT_GROUP, NOTIFY_SECS
# Arguments:
#   $1 - message
#######################################
notify_transient() {
  local message="${1}"
  log::info "notify | secs='${NOTIFY_SECS}' message='${message}'"
  "${NOTIFIER}" -title "go/pr" -message "${message}" -group "${ALERT_GROUP}" >/dev/null
  nohup zsh -c "sleep ${NOTIFY_SECS} && '${NOTIFIER}' -remove '${ALERT_GROUP}' >/dev/null 2>&1" \
    </dev/null >/dev/null 2>&1 &
}

# --- Main ---

main() {
  log::debug "=== run started | pid=$$ args='${*}' ==="

  check_prerequisites || exit 1

  # === PARSE ===
  while (( $# > 0 )); do case "${1}" in
    -h|--help)  help; return 0 ;;
    --verbose)  shift ;;
    -*)         log::err "Unknown flag | flag='${1}'"; help; return 1 ;;
    *)          log::err "Unexpected argument | argument='${1}'"; help; return 1 ;;
  esac; done

  # === LOGIC ===
  log::info "Starting | notify_secs='${NOTIFY_SECS}'"

  local uuid
  if ! uuid="$("${SESSION_FROM_FOCUS}")"; then
    notify_transient "no claude session in focused pane"
    return 1
  fi
  log::debug "Focus resolved | uuid='${uuid}'"

  local pr
  if ! pr="$("${SESSION_PR}" "${uuid}")" || [[ -z "${pr}" ]]; then
    notify_transient "no active PR | claude_session='${uuid:0:8}'"
    return 1
  fi

  notify_transient "opening PR | pr='${pr}' claude_session='${uuid:0:8}'"
  open "http://go/pr/${pr}"
}

main "${@}"
