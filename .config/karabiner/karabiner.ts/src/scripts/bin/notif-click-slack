#!/usr/bin/env zsh
#
# Karabiner Hyper+C handler: click the newest chat (Slack) notification.
#
# Match by app, not text. Slack's title/subtitle/body carry the channel and
# message — never the workspace name or "Slack" — so a pure-AX text match can't
# identify it. notif-center --app reads the Notification Center DB to target by
# app, which needs Full Disk Access for whatever runs this (under Hyper+C that's
# karabiner_console_user_server). Without FDA the read fails the same way as
# "no Slack notification", so we detect the unreadable DB and surface it loudly
# instead of failing silently.
set -euo pipefail

export OTTO_LOG_NOTIF_GROUP="notif-click-slack"
export OTTO_LOG_NOTIF_TITLE="Hyper+C → Slack"
export OTTO_DEBUG="${OTTO_DEBUG:-0}"
source "${HOME}/.config/zsh/plugins/log.zsh"

readonly NOTIF_DB="${HOME}/Library/Group Containers/group.com.apple.usernoted/db2/db"
readonly FDA_BIN="/Library/Application Support/org.pqrs/Karabiner-Elements/bin/karabiner_console_user_server"
readonly SCRIPT_DIR="${0:A:h}"

# -r only checks mode bits; TCC denies at open() time, so actually read a byte.
if ! head -c1 "${NOTIF_DB}" >/dev/null 2>&1; then
  log::err "Notification DB unreadable — Full Disk Access missing | bin='${FDA_BIN}'"
  # Persistent (not auto-removed) notification, clickable to re-stage the grant.
  if command -v terminal-notifier >/dev/null 2>&1; then
    terminal-notifier \
      -title "Hyper+C → Slack needs Full Disk Access" \
      -subtitle "Settings opened, path copied — just paste it in" \
      -message "Grant FDA to karabiner_console_user_server, then restart Karabiner. Click to reopen." \
      -group "notif-click-slack-fda" \
      -execute "${SCRIPT_DIR}/set-fda-perms" >/dev/null 2>&1 || true
  fi
  "${SCRIPT_DIR}/set-fda-perms" "${FDA_BIN}" || true
  exit 1
fi

exec notif-center click --app slack
