#!/bin/bash
#
# Pre-commit hook for the dotfiles bare repo.
# Ensures karabiner.json is sorted by key before committing.
#
# Setup (after fresh clone):
#   git df config core.hooksPath ~/.config/git/dotfiles-hooks

set -euo pipefail

readonly C_RED='\033[31m'
readonly C_GREEN='\033[32m'
readonly C_YELLOW='\033[33m'
readonly C_RST='\033[0m'

log::err()  { echo -e "${C_RED}[ERROR]${C_RST} $*" >&2; }
log::warn() { echo -e "${C_YELLOW}[WARN]${C_RST} $*" >&2; }
log::info() { echo -e "${C_GREEN}[INFO]${C_RST} $*" >&2; }

main() {
  # git diff --cached --name-only emits paths relative to the repo root, and
  # the bare repo's worktree is $HOME — so match the repo-relative path, not an
  # absolute one (grep -qx needs a full-line match).
  local rel=".config/karabiner/karabiner.json"

  # Only check if karabiner.json is staged.
  if ! git diff --cached --name-only | grep -qx "${rel}"; then
    return 0
  fi

  log::info "Checking ${rel} is sorted by key..."

  local sorted staged
  sorted="$(git show ":${rel}" | jq --sort-keys)"
  staged="$(git show ":${rel}")"

  if [[ "${sorted}" != "${staged}" ]]; then
    log::err "${rel} is not sorted by key."
    log::warn "The generator writes this file with non-canonical key ordering."
    log::warn "Run 'bake' from ~/.config/karabiner to regenerate and sort, then re-stage."
    return 1
  fi

  log::info "karabiner.json is properly sorted."
}

main "$@"
